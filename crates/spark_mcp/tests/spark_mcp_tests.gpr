--  Standalone test driver for the json-free spark_mcp core (Writer + the
--  pre-parsed Respond routing). Kept dependency-light on purpose -- no AUnit --
--  so it runs the moment the library builds. -gnata turns Writer's SPARK
--  Pre/Post into executable checks, so a contract violation fails the run.

with "../spark_mcp.gpr";

project Spark_Mcp_Tests is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("test_spark_mcp.adb");
   for Create_Missing_Dirs use "True";

   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-gnata", "-gnatwa", "-gnatyM99");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es");
   end Binder;

end Spark_Mcp_Tests;
